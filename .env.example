# ── Supabase (Fase 1) ────────────────────────────────────────
# Isi untuk mengaktifkan autentikasi & database. Bila kosong, aplikasi
# berjalan dalam MODE DEMO memakai data contoh (tanpa login).
# Ambil dari Supabase self-host Anda (Studio → Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — HANYA server, untuk skrip admin/seed (opsional). Jangan diekspos ke klien.
SUPABASE_SERVICE_ROLE_KEY=

# ── Gemini (tutor AI) ────────────────────────────────────────
# Tanpa key ini, /api/tutor memakai jawaban contoh (stub).
GEMINI_API_KEY=
